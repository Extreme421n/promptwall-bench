# DemoCorp frontend environment variables.
#
# Copy to `.env.local` (gitignored) and edit. Vite only exposes variables
# prefixed with `VITE_` to the browser bundle — never put secrets here.

# Base URL of the DemoCorp backend (FastAPI uvicorn server).
# When omitted, the API client falls back to http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000
