# DemoCorp backend environment variables.
#
# Copy to `.env` (gitignored) and edit. In production, set these via your
# host's environment / secrets manager — DO NOT commit a populated .env.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
#
# Local Docker Postgres (matches docker-compose.yml):
DATABASE_URL=postgresql+psycopg://promptwall:promptwall@localhost:5544/promptwall_bench
#
# Local Homebrew Postgres:
#   DATABASE_URL=postgresql+psycopg://$USER@localhost:5432/promptwall_bench
#
# Local SQLite (no Postgres needed; small/medium scale only):
#   DATABASE_URL=sqlite:///./democorp.db
#
# Managed Postgres (Render / Railway / Fly / Supabase / Neon):
#   DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/DBNAME

# Used by tests; SQLite is the default if unset.
TEST_DATABASE_URL=sqlite:///./test.db

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
#
# `mock`               — deterministic heuristic; no network; no API key.
# `openai_compatible`  — real LLM via OpenAI API or any OpenAI-compatible host
#                        (Groq, Together, vLLM, etc.).
LLM_PROVIDER=mock
DEFAULT_MODEL=mock-1

# Required only when LLM_PROVIDER=openai_compatible OR when the /chat
# endpoint is called with a non-mock model. Leave OPENAI_BASE_URL unset to
# use OpenAI directly; set it to point at a compatible provider.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# HTTP / CORS
# ---------------------------------------------------------------------------
#
# Comma-separated list of allowed frontend origins. The literal value `*`
# allows any origin (development only — automatically disables credentials).
#
# Local development (Vite + CRA + common dev ports are already the default):
#   CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
#
# Production (point at your frontend's public URL):
#   CORS_ORIGINS=https://demo.example.com,https://staging.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# HTTP server (when running uvicorn directly)
# ---------------------------------------------------------------------------
#
# These are not consumed by Settings — they're hints for shell commands.
# Most managed platforms (Render, Railway, Fly) inject $PORT themselves; the
# Docker image's CMD honours it.
# PORT=8000
