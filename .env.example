# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://promptwall:promptwall@localhost:5544/promptwall_bench

# Used by tests; SQLite is the default if unset
TEST_DATABASE_URL=sqlite:///./test.db

# LLM provider selection: mock | openai_compatible
LLM_PROVIDER=mock
DEFAULT_MODEL=mock-1

# Required only when LLM_PROVIDER=openai_compatible or when calling a non-mock
# model through the /chat endpoint. Leave OPENAI_BASE_URL unset to use OpenAI;
# set it to a custom URL for compatible providers (e.g. Groq, Together, vLLM).
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
